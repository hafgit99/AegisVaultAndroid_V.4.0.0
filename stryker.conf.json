{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "jest",
  "concurrency": "50%",
  "checkers": [],
  "jest": {
    "projectType": "custom",
    "configFile": "jest.mutation.config.js",
    "enableFindRelatedTests": true
  },
  "mutate": [
    "src/SecurityModule.ts",
    "src/SyncCryptoService.ts",
    "src/FileEncryptionModule.ts",
    "src/VaultManager.ts",
    "src/CloudSyncModule.ts",
    "src/DeltaSyncModule.ts",
    "src/SyncConflictService.ts",
    "src/SyncManager.ts",
    "src/SyncDeviceService.ts",
    "src/WearSyncCrypto.ts",
    "src/PasskeyModule.ts",
    "src/PasskeyEnrollmentService.ts",
    "src/PasskeyRpApi.ts",
    "src/PasskeyBindingService.ts",
    "src/EmergencyAccessModule.ts",
    "src/RecoveryModule.ts",
    "src/HIBPModule.ts",
    "src/IntegrityModule.ts",
    "src/TOTPModule.ts",
    "src/BackupModule.ts",
    "src/AutofillService.ts",
    "src/SearchService.ts",
    "src/SecureAppSettings.ts",
    "src/SecurityCenterService.ts",
    "src/SharedSpaceService.ts",
    "src/PasswordHistoryModule.ts",
    "src/ImportVersioning.ts",
    "src/AppMonitoring.ts",
    "src/SharingAuditService.ts",
    "src/SyncEnvelope.ts",
    "src/WearOSModule.ts"
  ],
  "incremental": true,
  "incrementalFile": "reports/stryker-incremental.json",
  "ignoreStatic": true,
  "reporters": [
    "clear-text",
    "html",
    "json"
  ],
  "coverageAnalysis": "perTest",
  "allowConsoleColors": true,
  "timeoutMS": 60000,
  "tempDirName": ".stryker-tmp"
}
